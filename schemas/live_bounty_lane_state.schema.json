{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.cybersec-lab/schemas/live_bounty_lane_state.schema.json",
  "title": "Live bounty lane state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "program_slug",
    "lane_id",
    "lane_title",
    "autonomy_level",
    "state",
    "status",
    "authorization",
    "lane_boundary",
    "operator_gates",
    "stop_conditions",
    "next_autonomous_action",
    "next_operator_action",
    "artifacts",
    "learning",
    "updated_at"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "program_slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"},
    "lane_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,96}$"},
    "lane_title": {"type": "string", "minLength": 3},
    "autonomy_level": {"enum": ["A0", "A1", "A2", "A3", "A4"]},
    "operator_decision": {
      "description": "Operator-facing decision vocabulary from PROJECT_CHARTER.md.",
      "enum": ["EXECUTE", "PASSIVE_ONLY", "PARK", "KILL"]
    },
    "machine_state": {
      "description": "Runner-facing lane state alias. During migration this should mirror state.",
      "enum": [
        "POLICY_INTAKE",
        "SCOPE_DRAFTED",
        "SCOPE_CONFIRMED",
        "DRY_RUN_GATE_PASSED",
        "A2_PENDING_OPERATOR_AUTH",
        "A2_SURFACE_MAP_RUNNING",
        "A2_SURFACE_MAP_COMPLETE",
        "A3_PREVIEW_REQUIRED",
        "CANDIDATE_REVIEW",
        "NO_FINDING_CLOSEOUT",
        "REPORT_PACKET_READY",
        "PARKED"
      ]
    },
    "state": {
      "enum": [
        "POLICY_INTAKE",
        "SCOPE_DRAFTED",
        "SCOPE_CONFIRMED",
        "DRY_RUN_GATE_PASSED",
        "A2_PENDING_OPERATOR_AUTH",
        "A2_SURFACE_MAP_RUNNING",
        "A2_SURFACE_MAP_COMPLETE",
        "A3_PREVIEW_REQUIRED",
        "CANDIDATE_REVIEW",
        "NO_FINDING_CLOSEOUT",
        "REPORT_PACKET_READY",
        "PARKED"
      ]
    },
    "status": {
      "enum": [
        "ready",
        "running",
        "blocked_operator_action",
        "blocked_awaiting_scope",
        "blocked_policy_ambiguity",
        "blocked_stronger_technique",
        "surface_only",
        "candidate",
        "needs_manual_review",
        "no_finding",
        "report_ready",
        "parked"
      ]
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["program_url", "scope_file", "global_scope_entries", "dry_run_gate", "out_of_scope_control"],
      "properties": {
        "program_url": {"type": "string", "format": "uri"},
        "scope_file": {"type": "string", "minLength": 1},
        "global_scope_entries": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "dry_run_gate": {"enum": ["not_run", "passed", "failed", "not_applicable"]},
        "out_of_scope_control": {"enum": ["not_run", "failed_closed", "unexpected_pass", "not_applicable"]}
      }
    },
    "lane_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_actions", "blocked_actions", "identity_strategy"],
      "properties": {
        "allowed_actions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "blocked_actions": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "identity_strategy": {"type": "string", "minLength": 1}
      }
    },
    "operator_gates": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "stop_conditions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "next_autonomous_action": {"type": "string", "minLength": 1},
    "next_operator_action": {"type": "string", "minLength": 1},
    "artifacts": {
      "type": "object",
      "additionalProperties": {"type": "string"},
      "required": ["dry_run_packet", "evidence_dir"],
      "properties": {
        "dry_run_packet": {"type": "string", "minLength": 1},
        "evidence_dir": {"type": "string", "minLength": 1},
        "latest_evidence": {"type": "string", "minLength": 1}
      }
    },
    "learning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preview_references", "next_preview_seed"],
      "properties": {
        "preview_references": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "next_preview_seed": {"type": "string", "minLength": 1},
        "reusable_capability": {"type": "string"}
      }
    },
    "updated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}"}
  }
}
