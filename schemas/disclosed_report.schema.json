{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.cybersec-lab/schemas/disclosed_report.schema.json",
  "title": "Disclosed report normalized record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source",
    "url",
    "title",
    "source_visibility",
    "status",
    "target_touching",
    "summary",
    "vulnerability_classes",
    "primitives",
    "proof_shapes",
    "impact_shapes",
    "product_surface_keywords",
    "route_patterns",
    "report_quality_signals",
    "safety_tags",
    "blocked_actions"
  ],
  "properties": {
    "schema_version": {"const": "disclosed_report/0.1"},
    "source": {"type": "string", "minLength": 1},
    "url": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "source_visibility": {"enum": ["public", "needs_operator_or_browser_review"]},
    "status": {"enum": ["ok", "needs_operator_or_browser_review"]},
    "target_touching": {"const": false},
    "summary": {"type": "string"},
    "vulnerability_classes": {"type": "array", "items": {"type": "string"}},
    "primitives": {"type": "array", "items": {"type": "string"}},
    "proof_shapes": {"type": "array", "items": {"type": "string"}},
    "impact_shapes": {"type": "array", "items": {"type": "string"}},
    "product_surface_keywords": {"type": "array", "items": {"type": "string"}},
    "route_patterns": {"type": "array", "items": {"type": "string"}},
    "report_quality_signals": {"type": "array", "items": {"type": "string"}},
    "safety_tags": {"type": "array", "items": {"type": "string"}},
    "blocked_actions": {"type": "array", "items": {"type": "string"}}
  }
}
